{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private information for a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "employee"] },
        "avatarUrl": { "type": "string", "format": "uri" },
        "fcmTokens": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "Enterprise client information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "lead"] },
        "notes": { "type": "string" },
        "assignedManagerId": { "type": "string" },
        "totalProjects": { "type": "number", "default": 0 },
        "totalSpent": { "type": "number", "default": 0 },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "email", "status", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Client project details and status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "string" },
        "promisedFeatures": { "type": "array", "items": { "type": "string" } },
        "outOfScope": { "type": "array", "items": { "type": "string" } },
        "price": { "type": "number", "default": 0 },
        "status": { "type": "string", "enum": ["lead", "active", "completed", "on_hold"] },
        "startDate": { "type": "number" },
        "endDate": { "type": "number" },
        "completionDate": { "type": "number" },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "maintenanceYears": { "type": "number", "default": 1 },
        "liveLink": { "type": "string" },
        "stagingLink": { "type": "string" },
        "repoLink": { "type": "string" },
        "credentials": { "type": "string" },
        "meetingNotes": { "type": "array", "items": { 
          "type": "object",
          "properties": {
            "date": { "type": "number" },
            "summary": { "type": "string" }
          }
        }},
        "teamIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "clientId", "title", "status", "createdAt"]
    },
    "GlobalStats": {
      "title": "Global Statistics",
      "description": "Aggregated metrics for the organization.",
      "type": "object",
      "properties": {
        "totalSales": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "totalProjects": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["totalSales", "totalEarnings", "totalProjects", "updatedAt"]
    },
    "Channel": {
      "title": "Chat Channel",
      "description": "A public or private chat room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private", "project"] },
        "projectId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "type", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "An individual chat message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "channelId": { "type": "string" },
        "recipientId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "attachments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "senderId", "senderName", "text", "timestamp"]
    },
    "InternalEmail": {
      "title": "Internal Email",
      "description": "An internal message sent between organization members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "recipientIds": { "type": "array", "items": { "type": "string" } },
        "recipientEmails": { "type": "array", "items": { "type": "string" } },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "priority": { "type": "string", "enum": ["normal", "high", "urgent"] },
        "timestamp": { "type": "number" },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "attachments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "required": ["senderId", "recipientIds", "subject", "body", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for all members of the platform."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Master list of enterprise clients."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Client-linked projects."
    },
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Chat channels."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages (global collection for easier querying)."
    },
    "/internal_emails/{emailId}": {
      "schema": "InternalEmail",
      "description": "Internal organizational emails."
    },
    "/system_stats/global": {
      "schema": "GlobalStats",
      "description": "Global performance metrics."
    }
  }
}
