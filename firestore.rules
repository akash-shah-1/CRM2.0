rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }
    
    function isNotDisabled() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (!exists(path) || (
        !get(path).data.keys().hasAny(['status']) || 
        get(path).data.status != 'disabled'
      ));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        (exists(path) && get(path).data.role == 'admin') || 
        request.auth.token.email == 'akash.s@cisinlabs.com' ||
        request.auth.token.email == 'admin@nexus.com'
      );
    }

    function isManager() {
      return isSignedIn() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'manager'));
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt'])
        && data.keys().size() >= 5
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.role in ['admin', 'manager', 'employee']
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'status', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.status in ['active', 'inactive', 'lead']
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'status', 'clientId', 'createdAt'])
        && data.title is string && data.title.size() <= 256
        && data.status in ['lead', 'active', 'completed', 'on_hold']
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidGlobalStats(data) {
      return data.keys().hasAll(['totalSales', 'totalEarnings', 'totalProjects', 'updatedAt'])
        && data.totalSales is number
        && data.totalEarnings is number
        && data.totalProjects is number;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['name', 'type', 'projectId', 'uploadedBy', 'uploadedByUid', 'createdAt'])
        && data.name is string && data.name.size() <= 256
        && data.type is string && data.type.size() <= 20
        && data.projectId is string && data.projectId.size() <= 128
        && data.uploadedBy is string && data.uploadedBy.size() <= 128
        && data.uploadedByUid == request.auth.uid
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'projectId', 'createdAt'])
        && data.title is string && data.title.size() <= 256
        && data.content is string && data.content.size() <= 20000
        && data.projectId is string && data.projectId.size() <= 128
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'senderName', 'text', 'timestamp'])
        && data.senderId is string
        && data.senderName is string
        && data.text is string && data.text.size() <= 6000
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'type', 'userId', 'read', 'timestamp'])
        && data.title is string && data.title.size() <= 128
        && data.message is string && data.message.size() <= 512
        && data.type in ['info', 'success', 'warning', 'error']
        && data.userId is string && data.userId.size() <= 128
        && data.read is bool
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    function isValidChannel(data) {
      return data.keys().hasAll(['name', 'type', 'creatorId', 'participants', 'createdAt'])
        && data.name is string && data.name.size() <= 64
        && data.type in ['public', 'private']
        && data.creatorId is string
        && data.participants is list
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['userId', 'userName', 'action', 'target', 'timestamp'])
        && data.userId is string
        && data.userName is string
        && data.action is string
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    function isValidCommunication(data) {
      return data.keys().hasAll(['fromId', 'fromName', 'fromEmail', 'toEmail', 'subject', 'message', 'timestamp', 'status'])
        && data.fromId == request.auth.uid
        && data.fromEmail is string
        && data.toEmail is string
        && data.subject is string && data.subject.size() <= 256
        && data.message is string && data.message.size() <= 10000
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    function isValidInternalEmail(data) {
      return data.keys().hasAll(['senderId', 'recipientIds', 'subject', 'body', 'timestamp'])
        && data.senderId == request.auth.uid
        && data.recipientIds is list && data.recipientIds.size() >= 1
        && data.subject is string && data.subject.size() <= 256
        && data.body is string && data.body.size() <= 20000
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn(); 

      allow create: if isVerified() 
        && isOwner(userId)
        && isValidId(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.uid == userId;

      allow update: if isVerified()
        && isNotDisabled()
        && isValidUser(request.resource.data)
        && request.resource.data.uid == userId
        && (
          isAdmin() ||
          (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'status', 'lastSeen', 'lastViewed', 'defaultPage', 'uid', 'email', 'createdAt']))
        );

      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow get: if isSignedIn() && isNotDisabled();
      allow list: if isSignedIn();
      allow create: if isVerified() && isManager() && isNotDisabled() && isValidClient(request.resource.data);
      allow update: if isVerified() && isManager() && isNotDisabled() && isValidClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && isNotDisabled();
      allow list: if isSignedIn();
      allow create: if (isVerified() && isManager() && isNotDisabled() && isValidProject(request.resource.data)) || isAdmin();
      allow update: if (isVerified() && isManager() && isNotDisabled() && isValidProject(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /channels/{channelId} {
      allow get, list: if isSignedIn() && isNotDisabled();
      allow create: if isVerified() && isNotDisabled() && isValidChannel(request.resource.data);
      allow update: if isVerified() && isNotDisabled() && isValidChannel(request.resource.data) && (
        isAdmin() || 
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isAdmin() || (isVerified() && resource.data.creatorId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow get, list: if isSignedIn() && isNotDisabled(); 
      allow create: if isVerified() && isNotDisabled() && isValidMessage(request.resource.data) && (
        request.resource.data.senderId == request.auth.uid
      );
      allow update: if isVerified() && isNotDisabled() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) && (request.auth.uid in request.resource.data.readBy || request.auth.uid in resource.data.participants)) ||
        isAdmin() || 
        (resource.data.senderId == request.auth.uid && isValidMessage(request.resource.data))
      ); 
      allow delete: if isVerified() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
      allow create: if isVerified() && isValidNotification(request.resource.data);
      allow update: if isVerified() && isValidNotification(request.resource.data) && (
        (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin())) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
      );
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
    }

    match /communications/{commId} {
      allow get: if isSignedIn() && (resource.data.fromId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.fromId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isNotDisabled() && isValidCommunication(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /internal_emails/{emailId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || request.auth.uid in resource.data.recipientIds || isAdmin());
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || request.auth.uid in resource.data.recipientIds || isAdmin());
      allow create: if isVerified() && isNotDisabled() && isValidInternalEmail(request.resource.data);
      allow update: if isVerified() && isNotDisabled() && (
        (request.auth.uid in resource.data.recipientIds && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && (resource.data.senderId == request.auth.uid || request.auth.uid in resource.data.recipientIds));
    }

    match /activity/{activityId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidActivity(request.resource.data) && request.resource.data.userId == request.auth.uid;
    }

    match /documents/{docId} {
      allow get: if isSignedIn() && isNotDisabled();
      allow list: if isSignedIn() && (isAdmin() || resource.data.uploadedByUid == request.auth.uid || resource.data.projectId != null);
      allow create: if isVerified() && isNotDisabled() && isValidDocument(request.resource.data);
      allow update: if isVerified() && isNotDisabled() && (
        isAdmin() || 
        (resource.data.uploadedByUid == request.auth.uid)
      ) && isValidDocument(request.resource.data);
      allow delete: if isVerified() && (isAdmin() || resource.data.uploadedByUid == request.auth.uid);
    }

    match /notes/{noteId} {
      allow get, list: if isSignedIn() && isNotDisabled();
      allow create: if isVerified() && isNotDisabled() && isValidNote(request.resource.data);
      allow update: if isVerified() && isNotDisabled() && (
        isAdmin() || 
        resource.data.authorId == request.auth.uid
      ) && isValidNote(request.resource.data);
      allow delete: if isVerified() && (isAdmin() || resource.data.authorId == request.auth.uid);
    }

    match /system_stats/{statId} {
      allow get, list: if isSignedIn() && isNotDisabled();
      allow write: if isVerified() && isManager() && isNotDisabled() && isValidGlobalStats(request.resource.data);
    }
  }
}
