rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email.split('@')[1] == 'nexus.com'
      );
    }
    
    function isNotDisabled() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (!exists(path) || (
        !get(path).data.keys().hasAny(['status']) || 
        get(path).data.status != 'disabled'
      ));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        (exists(path) && get(path).data.role == 'admin') || 
        request.auth.token.email == 'akash.s@cisinlabs.com' ||
        request.auth.token.email == 'admin@nexus.com'
      );
    }

    function isManager() {
      return isSignedIn() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'manager'));
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt'])
        && data.keys().size() >= 5
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.role in ['admin', 'manager', 'employee']
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'status', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.status in ['active', 'inactive', 'lead']
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'status', 'clientId', 'createdAt'])
        && data.name is string && data.name.size() <= 128
        && data.status in ['active', 'completed', 'on-hold', 'planning']
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['name', 'type', 'projectId', 'uploadedBy', 'uploadedByUid', 'createdAt'])
        && data.name is string && data.name.size() <= 256
        && data.type is string && data.type.size() <= 20
        && data.projectId is string && data.projectId.size() <= 128
        && data.uploadedBy is string && data.uploadedBy.size() <= 128
        && data.uploadedByUid == request.auth.uid
        && (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'senderName', 'text', 'timestamp', 'participants'])
        && data.senderId is string
        && data.participants is list && data.participants.size() >= 1 && data.participants.size() <= 50
        && (request.auth.uid in data.participants || data.senderId == request.auth.uid)
        && data.text is string && data.text.size() <= 6000
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'type', 'userId', 'read', 'timestamp'])
        && data.title is string && data.title.size() <= 128
        && data.message is string && data.message.size() <= 512
        && data.type in ['info', 'success', 'warning', 'error']
        && data.userId is string && data.userId.size() <= 128
        && data.read is bool
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    function isValidCommunication(data) {
      return data.keys().hasAll(['fromId', 'fromName', 'fromEmail', 'toEmail', 'subject', 'message', 'timestamp', 'status'])
        && data.fromId == request.auth.uid
        && data.fromEmail is string
        && data.toEmail is string
        && data.subject is string && data.subject.size() <= 256
        && data.message is string && data.message.size() <= 10000
        && (data.timestamp is number || data.timestamp is timestamp);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn(); 

      allow create: if isVerified() 
        && isOwner(userId)
        && isValidId(userId)
        && isValidUser(request.resource.data);

      allow update: if isVerified()
        && isNotDisabled()
        && (
          isAdmin() ||
          (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'avatarUrl', 'status', 'lastSeen']))
        );

      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow get: if isSignedIn() && isNotDisabled();
      allow list: if isSignedIn();
      allow create: if isVerified() && isManager() && isNotDisabled() && isValidClient(request.resource.data);
      allow update: if isVerified() && isManager() && isNotDisabled() && isValidClient(request.resource.data) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email', 'status', 'phone']);
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && isNotDisabled();
      allow list: if isSignedIn();
      allow create: if isVerified() && isManager() && isNotDisabled() && isValidProject(request.resource.data);
      allow update: if isVerified() && isManager() && isNotDisabled() && isValidProject(request.resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'status', 'clientId']);
      allow delete: if isAdmin();
    }

    match /channels/{channelId} {
      allow get, list: if isSignedIn() && isNotDisabled();
      allow create: if isVerified() && isNotDisabled();
      allow update: if isVerified() && isNotDisabled() && (
        isAdmin() || 
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isAdmin() || (isVerified() && resource.data.creatorId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow get, list: if isSignedIn() && isNotDisabled(); 
      allow create: if isVerified() && isNotDisabled() && isValidMessage(request.resource.data);
      allow update: if isVerified() && isNotDisabled() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
        isAdmin() || 
        resource.data.senderId == request.auth.uid
      ); 
      allow delete: if isVerified() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
      allow list: if isSignedIn();
      allow create: if isVerified();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /communications/{commId} {
      allow get: if isSignedIn() && (resource.data.fromId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.fromId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isNotDisabled() && isValidCommunication(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /activity/{activityId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /documents/{docId} {
      allow get: if isSignedIn() && isNotDisabled();
      allow list: if isSignedIn() && (isAdmin() || resource.data.uploadedByUid == request.auth.uid || resource.data.projectId != null);
      allow create: if isVerified() && isNotDisabled() && isValidDocument(request.resource.data);
      allow update: if isVerified() && isNotDisabled() && (
        isAdmin() || 
        (resource.data.uploadedByUid == request.auth.uid)
      ) && isValidDocument(request.resource.data);
      allow delete: if isVerified() && (isAdmin() || resource.data.uploadedByUid == request.auth.uid);
    }
  }
}
